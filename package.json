{
  "name": "google-search-console-updater",
  "version": "1.0.7",
  "description": "Portable app for Google Search Console URL inspection and indexing requests",
  "main": "electron/main.cjs",
  "author": "Marfa",
  "license": "CC-BY-NC-SA-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Marfa/Google_Search_Console_Index_Updater.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac zip",
    "build:mac": "electron-builder --mac zip",
    "build:win": "node scripts/build-win.mjs",
    "package:win": "node scripts/package-win-release.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "build:publish": "electron-builder --mac zip --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "google-auth-library": "^9.15.1"
  },
  "devDependencies": {
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "pe-library": "^1.0.1",
    "png-to-ico": "^3.0.1",
    "resedit": "^3.0.2",
    "archiver": "^7.0.1",
    "sharp": "^0.35.1"
  },
  "build": {
    "appId": "com.marfa.gsc-updater",
    "productName": "Google Search Console Updater",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist"
    },
    "electronLanguages": [
      "en",
      "ru"
    ],
    "afterPack": "scripts/after-pack.cjs",
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "build/icon.png",
      "build/icon.ico",
      "config.example.json",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Marfa",
        "repo": "Google_Search_Console_Index_Updater"
      }
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "Google-Search-Console-Updater-${version}-mac-arm64.${ext}",
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Google-Search-Console-Updater-${version}-win-x64.${ext}"
    }
  }
}
